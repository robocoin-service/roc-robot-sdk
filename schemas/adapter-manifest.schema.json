{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/robocoin-service/roc-robot-sdk/schemas/adapter-manifest.schema.json",
  "title": "ROC Robot Adapter Manifest",
  "type": "object",
  "required": [
    "manifestVersion",
    "id",
    "displayName",
    "version",
    "platform",
    "protocol",
    "capabilities",
    "jobTypes",
    "entrypoint"
  ],
  "properties": {
    "$schema": {"type": "string"},
    "manifestVersion": {"const": 1},
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
    },
    "displayName": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "platform": {"const": "linux"},
    "protocol": {"const": "roc.adapter.jsonl.v1"},
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "jobTypes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[A-Z][A-Z0-9_-]*$"}
    },
    "requires": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "entrypoint": {
      "oneOf": [
        {"type": "string", "minLength": 1},
        {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      ]
    },
    "configuration": {"type": "object"}
  },
  "additionalProperties": false
}
